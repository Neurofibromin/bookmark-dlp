<UserControl
    x:Class="bookmark_dlp.Views.SettingsView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <StackPanel>
        <TextBox
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            FontWeight="Bold">
            Settings
        </TextBox>
        <CheckBox Margin="4" IsChecked="{Binding DownloadPlaylists}">
            Playlists
        </CheckBox>
        <CheckBox Margin="4" IsChecked="{Binding DownloadShorts}">
            Shorts
        </CheckBox>
        <CheckBox Margin="4" IsChecked="{Binding DownloadChannels}">
            Channels
        </CheckBox>
        <CheckBox Margin="4" IsChecked="{Binding Concurrent_downloads}">
            Concurrent downloads
        </CheckBox>
        <CheckBox Margin="4" IsChecked="{Binding Cookies_autoextract}">
            Cookies autoextract
        </CheckBox>
        <Grid Margin="4" ColumnDefinitions="Auto,*,Auto,Auto">
            <Label Grid.Column="0" FontSize="9">Current yt-dlp execuatble path:</Label>
            <Label
                Grid.Column="1"
                Background="Red"
                Content="{Binding Yt_dlp_binary_path}" />
            <Button
                Grid.Column="2"
                VerticalAlignment="Top"
                Command="{Binding ChooseYtdlpBinaryCommand}"
                FontSize="9">
                Select executable file
            </Button>

        </Grid>
        <Button
            Margin="4"
            Command="{Binding $parent[Window].DataContext.GoBack}"
            FontSize="9">
            Save settings
        </Button>

    </StackPanel>
</UserControl>
