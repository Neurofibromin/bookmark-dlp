# Maintainer: Neurofibromin <125222560+Neurofibromin@users.noreply.github.com>
# Contributor: Neurofibromin <125222560+Neurofibromin@users.noreply.github.com>
_sourceName="bookmark-dlp"
_dotnet_version=10.0

pkgname="bookmark-dlp"
pkgver=0.4.3
pkgrel=1
pkgdesc="Small utility program for downloading bookmarked YouTube links using yt-dlp."
arch=("x86_64")
url="https://github.com/Neurofibromin/bookmark-dlp"
license=('GPL-3.0-only')
depends=(
    gcc-libs
    glibc
    yt-dlp
)
makedepends=(
    "dotnet-sdk-${_dotnet_version}"
)
optdepends=()
options=(staticlibs
         !strip    )
source=("${pkgname}-${pkgver}.tar.gz::${url}/archive/refs/tags/${pkgver}.tar.gz")
validpgpkeys=('9F9BFE94618AD26667BD28214F671AFAD8D4428B')
b2sums=('5d6d98068b0a330f09144e916bcc99d2aac92ae83efe0fa19f2ea5065f299d8140242771c5d7755898ac720b86fbc42e8407eccbda811870671460b568f695fb')

prepare() {
  cd "${srcdir}/${pkgname}-${pkgver}"
  export NUGET_PACKAGES="${PWD}/nuget"
  export DOTNET_NOLOGO=true
  export DOTNET_CLI_TELEMETRY_OPTOUT=true
  dotnet restore --locked-mode bookmark-dlp.sln
}

build() {
    cd "${srcdir}/${pkgname}-${pkgver}"
    MSBUILDDISABLENODEREUSE=1 dotnet publish bookmark-dlp/bookmark-dlp.csproj \
    --configuration Release \
    --runtime linux-x64 \
    --framework net${_dotnet_version} \
    --verbosity quiet \
    --output ${srcdir}/publish
}

check() {
  cd "${srcdir}/${pkgname}-${pkgver}"
  export NUGET_PACKAGES="${PWD}/nuget"
  export DOTNET_NOLOGO=true
  export DOTNET_CLI_TELEMETRY_OPTOUT=true
  dotnet test ./Tests/bookmark-dlp.Tests/ \
    --no-restore \
    --framework "net${_dotnet_version}" \
    --verbosity quiet
}

package() {
    # Ensure the directories exist
    install -d "${pkgdir}/usr/bin"
    install -d "${pkgdir}/usr/lib"
    install -d "${pkgdir}/usr/share"
    install -d "${pkgdir}/usr/share/applications"
    install -d "${pkgdir}/usr/share/icons/hicolor/{16x16,24x24,32x32,48x48,64x64,96x96,128x128,256x256,512x512,1024x1024}/apps"
    install -d "${pkgdir}/usr/share/icons/hicolor/scalable/apps"
    
    # Copy the package files to the appropriate directory
    cp -r "${srcdir}/publish/." "${pkgdir}/usr/lib/"
    
    # Create the symbolic link
    ln -s "/usr/lib/${_sourceName}" "${pkgdir}/usr/bin/${pkgname}"
    chmod +x "${pkgdir}/usr/lib/${_sourceName}"
    
    # install .desktop file
    install -m644 "${srcdir}/${pkgname}-${pkgver}/bookmark-dlp.desktop" "${pkgdir}/usr/share/applications/"
    
    # Install icons
    install -m644 "${srcdir}/${pkgname}-${pkgver}/bookmark-dlp/Assets/bookmark-dlp.16.png"   "${pkgdir}/usr/share/icons/hicolor/16x16/apps/bookmark-dlp.png"
    install -m644 "${srcdir}/${pkgname}-${pkgver}/bookmark-dlp/Assets/bookmark-dlp.24.png"   "${pkgdir}/usr/share/icons/hicolor/24x24/apps/bookmark-dlp.png"
    install -m644 "${srcdir}/${pkgname}-${pkgver}/bookmark-dlp/Assets/bookmark-dlp.32.png"   "${pkgdir}/usr/share/icons/hicolor/32x32/apps/bookmark-dlp.png"
    install -m644 "${srcdir}/${pkgname}-${pkgver}/bookmark-dlp/Assets/bookmark-dlp.48.png"   "${pkgdir}/usr/share/icons/hicolor/48x48/apps/bookmark-dlp.png"
    install -m644 "${srcdir}/${pkgname}-${pkgver}/bookmark-dlp/Assets/bookmark-dlp.64.png"   "${pkgdir}/usr/share/icons/hicolor/64x64/apps/bookmark-dlp.png"
    install -m644 "${srcdir}/${pkgname}-${pkgver}/bookmark-dlp/Assets/bookmark-dlp.96.png"   "${pkgdir}/usr/share/icons/hicolor/96x96/apps/bookmark-dlp.png"
    install -m644 "${srcdir}/${pkgname}-${pkgver}/bookmark-dlp/Assets/bookmark-dlp.128.png"  "${pkgdir}/usr/share/icons/hicolor/128x128/apps/bookmark-dlp.png"
    install -m644 "${srcdir}/${pkgname}-${pkgver}/bookmark-dlp/Assets/bookmark-dlp.256.png"  "${pkgdir}/usr/share/icons/hicolor/256x256/apps/bookmark-dlp.png"
    install -m644 "${srcdir}/${pkgname}-${pkgver}/bookmark-dlp/Assets/bookmark-dlp.512.png"  "${pkgdir}/usr/share/icons/hicolor/512x512/apps/bookmark-dlp.png"
    install -m644 "${srcdir}/${pkgname}-${pkgver}/bookmark-dlp/Assets/bookmark-dlp.1024.png" "${pkgdir}/usr/share/icons/hicolor/1024x1024/apps/bookmark-dlp.png"
    install -m644 "${srcdir}/${pkgname}-${pkgver}/bookmark-dlp/Assets/bookmark-dlp.svg" "${pkgdir}/usr/share/icons/hicolor/scalable/apps/bookmark-dlp.svg}"    
}
